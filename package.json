{
  "name": "erichk-resume",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "classnames": "^2.3.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "scripts": {
    "dev": "bun ./index.html",
    "build": "tsc --noEmit && bun build ./index.html --outdir=dist --minify",
    "check": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "prettier": "^2.3.1",
    "typescript": "^6.0.0"
  },
  "prettier": {
    "tabWidth": 4,
    "semi": false,
    "printWidth": 100,
    "trailingComma": "none",
    "overrides": [
      {
        "files": [
          "*.css",
          "*.scss",
          "*.json"
        ],
        "options": {
          "tabWidth": 2
        }
      }
    ]
  }
}
